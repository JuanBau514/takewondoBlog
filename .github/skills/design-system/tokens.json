{
  "colors": {
    "light": {
      "primary": {
        "red": "#DA1F50",
        "blue": "#0052CC",
        "yellow": "#FFD60A",
        "green": "#2D6A4F"
      },
      "neutral": {
        "white": "#FFFFFF",
        "black": "#0D0D0D",
        "gray": {
          "50": "#F8F8F8",
          "100": "#E8E8E8",
          "300": "#CCCCCC",
          "500": "#808080"
        }
      },
      "semantic": {
        "background": {
          "primary": "#FFFFFF",
          "secondary": "#F8F8F8",
          "tertiary": "#E8E8E8"
        },
        "text": {
          "primary": "#0D0D0D",
          "secondary": "#808080",
          "inverse": "#FFFFFF"
        },
        "interactive": {
          "primary": "#DA1F50",
          "primaryHover": "#B81640",
          "primaryActive": "#8F0F33",
          "secondary": "#0052CC",
          "success": "#2D6A4F",
          "warning": "#FFD60A",
          "disabled": "#CCCCCC",
          "disabledText": "#808080"
        }
      }
    },
    "dark": {
      "primary": {
        "red": "#FF4B6E",
        "blue": "#4A9EFF",
        "yellow": "#FED66D",
        "green": "#52B788"
      },
      "neutral": {
        "black": "#0D0D0D",
        "darkBg": "#0D0D0D",
        "darkSurface": "#1A1A1A",
        "darkBorder": "#2D2D2D",
        "darkText": "#F5F5F5",
        "darkTextSecondary": "#B0B0B0"
      },
      "semantic": {
        "background": {
          "primary": "#0D0D0D",
          "secondary": "#1A1A1A",
          "tertiary": "#2D2D2D"
        },
        "text": {
          "primary": "#F5F5F5",
          "secondary": "#B0B0B0",
          "inverse": "#0D0D0D"
        },
        "interactive": {
          "primary": "#FF4B6E",
          "primaryHover": "#FF6B89",
          "primaryActive": "#E63254",
          "secondary": "#4A9EFF",
          "success": "#52B788",
          "warning": "#FED66D",
          "disabled": "#2D2D2D",
          "disabledText": "#808080"
        }
      }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', sans-serif",
      "mono": "'Monaco', 'Courier New', monospace"
    },
    "fontSize": {
      "h1": {
        "size": "48px",
        "weight": 700,
        "usage": "Títulos principales, héroes"
      },
      "h2": {
        "size": "36px",
        "weight": 700,
        "usage": "Títulos de secciones"
      },
      "h3": {
        "size": "28px",
        "weight": 600,
        "usage": "Subtítulos"
      },
      "h4": {
        "size": "24px",
        "weight": 600,
        "usage": "Encabezados de cards"
      },
      "bodyLarge": {
        "size": "18px",
        "weight": 400,
        "usage": "Texto destacado"
      },
      "body": {
        "size": "16px",
        "weight": 400,
        "usage": "Texto principal"
      },
      "bodySmall": {
        "size": "14px",
        "weight": 400,
        "usage": "Texto secundario"
      },
      "caption": {
        "size": "12px",
        "weight": 400,
        "usage": "Labels, badges"
      },
      "code": {
        "size": "13px",
        "weight": 400,
        "usage": "Código inline"
      }
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "28px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px",
    "24": "96px"
  },
  "components": {
    "button": {
      "light": {
        "primary": {
          "background": "#DA1F50",
          "color": "#FFFFFF",
          "padding": "12px 24px",
          "borderRadius": "8px",
          "fontSize": "16px",
          "fontWeight": 600,
          "hover": "#B81640",
          "active": "#8F0F33",
          "disabled": "#CCCCCC"
        }
      },
      "dark": {
        "primary": {
          "background": "#FF4B6E",
          "color": "#0D0D0D",
          "padding": "12px 24px",
          "borderRadius": "8px",
          "fontSize": "16px",
          "fontWeight": 600,
          "hover": "#FF6B89",
          "active": "#E63254"
        }
      }
    },
    "card": {
      "light": {
        "background": "#FFFFFF",
        "border": "1px solid #E8E8E8",
        "borderRadius": "12px",
        "boxShadow": "0 2px 8px rgba(0, 0, 0, 0.08)",
        "padding": "24px",
        "hoverShadow": "0 8px 24px rgba(0, 0, 0, 0.12)"
      },
      "dark": {
        "background": "#1A1A1A",
        "border": "1px solid #2D2D2D",
        "borderRadius": "12px",
        "boxShadow": "0 2px 8px rgba(0, 0, 0, 0.3)",
        "padding": "24px",
        "hoverShadow": "0 8px 24px rgba(255, 255, 255, 0.05)"
      }
    },
    "input": {
      "light": {
        "background": "#F8F8F8",
        "border": "2px solid #E8E8E8",
        "borderRadius": "8px",
        "padding": "12px 16px",
        "fontSize": "16px",
        "focusBorder": "#0052CC",
        "focusShadow": "0 0 0 3px rgba(0, 82, 204, 0.1)",
        "textColor": "#0D0D0D",
        "placeholderColor": "#808080"
      },
      "dark": {
        "background": "#1A1A1A",
        "border": "2px solid #2D2D2D",
        "borderRadius": "8px",
        "padding": "12px 16px",
        "fontSize": "16px",
        "focusBorder": "#4A9EFF",
        "focusShadow": "0 0 0 3px rgba(74, 158, 255, 0.1)",
        "textColor": "#F5F5F5",
        "placeholderColor": "#808080"
      }
    }
  },
  "breakpoints": {
    "mobile": "640px",
    "tablet": "1024px",
    "desktop": "1440px"
  },
  "transitions": {
    "default": "all 200ms cubic-bezier(0.4, 0, 0.2, 1)"
  }
}
